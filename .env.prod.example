ENV=production

FRONTEND_DOMAIN=app.nestchat.online
API_DOMAIN=api.nestchat.online

VITE_API_URL=https://api.nestchat.online/api
VITE_WS_URL=wss://api.nestchat.online

DJANGO_SECRET_KEY=change-me-to-a-long-random-secret
DJANGO_ALLOWED_HOSTS=api.nestchat.online
CORS_ALLOWED_ORIGINS=https://app.nestchat.online
CSRF_TRUSTED_ORIGINS=https://app.nestchat.online,https://api.nestchat.online

DJANGO_SECURE_SSL_REDIRECT=true
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

POSTGRES_DB=nestchat_db
POSTGRES_USER=nestchat_user
POSTGRES_PASSWORD=change-me

RABBITMQ_DEFAULT_USER=nestchat
RABBITMQ_DEFAULT_PASS=change-me

LIVEKIT_API_KEY=change-me
LIVEKIT_API_SECRET=change-me

USE_S3_MEDIA=true
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=eu-frankfurt-1
AWS_S3_ENDPOINT_URL=https://<namespace>.compat.objectstorage.eu-frankfurt-1.oraclecloud.com
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_S3_CUSTOM_DOMAIN=
AWS_S3_SIGNATURE_VERSION=s3v4
AWS_S3_ADDRESSING_STYLE=path
